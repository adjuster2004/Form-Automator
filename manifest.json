{
  "manifest_version": 3,
  "name": "Form Automator",
  "version": "1.0",
  "description": "Записывает и повторяет действия в форме.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://site.site/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://site.site/*"],
      "js": ["content.js"]
    }
  ]
}